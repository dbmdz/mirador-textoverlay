{
  "name": "mirador-textoverlay",
  "version": "1.0.2",
  "description": "Mirador 4 plugin to render a hidden or visible selectable text overlay",
  "keywords": [
    "iiif",
    "mirador",
    "mirador4",
    "mirador-plugin",
    "react-component",
    "ocr",
    "transcription"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbmdz/mirador-textoverlay.git"
  },
  "license": "MIT",
  "author": "Johannes Baiter <johannes.baiter@bsb-muenchen.de>",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:demo && npm run build:plugin",
    "prebuild:demo": "rimraf demo/dist",
    "build:demo": "BUILD_MODE=demo vite build",
    "prebuild:plugin": "rimraf dist",
    "build:plugin": "vite build",
    "check": "npm run lint && npm run test && npm run build",
    "format": "eslint . --ext js,jsx --fix --max-warnings 0 --report-unused-disable-directives",
    "lint": "eslint . --ext js,jsx --max-warnings 0 --report-unused-disable-directives",
    "prepublishOnly": "npm run check",
    "prepreview": "npm run build:demo",
    "preview": "BUILD_MODE=demo vite preview",
    "start": "vite",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.3",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.x",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "isomorphic-unfetch": "^3.1.0",
    "jsdom": "^26.1.0",
    "lodash": "^4.17.11",
    "manifesto.js": "^4.2.0",
    "mirador": "4.1.0",
    "prettier": "^3.8.3",
    "prop-types": "^15.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redux-saga": "^1.1.3",
    "redux-saga-test-plan": "^4.0.0-rc.3",
    "reselect": "^5.0.0",
    "rimraf": "^6.1.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "mirador": "4.x",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "npm": ">=11.0.0"
  }
}
