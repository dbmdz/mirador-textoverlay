{
  "name": "mirador-textoverlay",
  "version": "0.4.0",
  "description": "Mirador 4 plugin to render a hidden or visible selectable text overlay",
  "keywords": [
    "iiif",
    "mirador",
    "mirador4",
    "mirador-plugin",
    "react-component",
    "ocr",
    "transcription"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dbmdz/mirador-textoverlay"
  },
  "license": "MIT",
  "author": "Johannes Baiter <johannes.baiter@bsb-muenchen.de>",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:demo && npm run build:plugin",
    "prebuild:demo": "rimraf demo/dist",
    "build:demo": "BUILD_MODE=demo vite build",
    "prebuild:plugin": "rimraf dist",
    "build:plugin": "vite build",
    "format": "eslint . --ext js,jsx --fix --max-warnings 0 --report-unused-disable-directives",
    "lint": "eslint . --ext js,jsx --max-warnings 0 --report-unused-disable-directives",
    "prepublishOnly": "npm run build",
    "prepreview": "npm run build:demo",
    "preview": "BUILD_MODE=demo vite preview",
    "start": "vite"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "isomorphic-unfetch": "^3.1.0",
    "lodash": "^4.17.21",
    "manifesto.js": "^4.3.2",
    "mirador": "^4.0.0",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "redux-saga": "^1.3.0",
    "reselect": "^5.1.1",
    "rimraf": "^6.1.3",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "mirador": "4.x",
    "react": "19.x",
    "react-dom": "19.x"
  },
  "engines": {
    "npm": ">=11.0.0"
  }
}
